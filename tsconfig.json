{
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/public-site/src/*"],
      "@shared/*": ["./packages/shared/*"]
    }
  },
  "include": [
    "apps/public-site/src/**/*.ts",
    "apps/public-site/src/**/*.tsx",
    "apps/admin/src/**/*.ts",
    "apps/admin/src/**/*.tsx",
    "packages/shared/**/*",
    "apps/public-site/vite.config.ts",
    "apps/admin/vite.config.ts"
  ],
  "exclude": [
    "apps/public-site/src/server",
    "apps/public-site/server"
  ]
}
